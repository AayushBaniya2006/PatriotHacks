# Data backend (FastAPI) base URL. Server-side only — read in
# lib/dataBackend.ts and never exposed to the browser (no NEXT_PUBLIC_
# prefix), so the backend never needs CORS.
#
# Local dev default matches `uvicorn app.main:app --port 8000` run from the
# repo root (see repo root README / CLAUDE.md "Run").
DATA_BACKEND_URL=http://localhost:8000

# When the backend is deployed (Railway), point this at its public URL
# instead, e.g.:
# DATA_BACKEND_URL=https://<your-backend>.up.railway.app
