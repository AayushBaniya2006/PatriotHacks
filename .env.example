OPENROUTER_API_KEY=your-openrouter-api-key-here

# Postgres. OPTIONAL. When set, the civic-match Next.js app (lib/store.ts) persists
# all runtime data — profiles, scenarios, graph, caches — to Postgres; when unset,
# it falls back to file-DB under data/ (zero-infra local/demo path). The Python
# serving layer (app/datastore.py) uses it too, else falls back to gold JSON under
# data/tx/. Matches docker-compose.yml locally; Railway injects its own in prod
# (add DATABASE_URL=${{Postgres.DATABASE_URL}} to the web service to connect it).
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/patriothacks

# Comma-separated origins allowed to call this API (civic-match frontend).
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Google Civic Information API key. OPTIONAL enrichment only (app/google_civic.py):
# when set, /api/ballot gains `voting_info` (polling/early-vote/drop-off locations)
# and `division_check` (cross-validates our Census-derived district against Google's
# OCD division data). Unset (the default) -> /api/ballot is byte-identical to today.
# Get a free key at console.cloud.google.com (enable "Google Civic Information API",
# then create a key under Credentials). Note: the API's `representatives` endpoint
# was shut down in 2025 and is not used here -- only elections/voterInfoQuery.
# GOOGLE_CIVIC_API_KEY=your-google-civic-api-key-here
