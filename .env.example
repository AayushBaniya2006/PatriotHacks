OPENROUTER_API_KEY=your-openrouter-api-key-here

# Postgres serving layer (optional -- app/datastore.py falls back to gold
# JSON under data/tx/ with no DATABASE_URL set). Matches docker-compose.yml
# locally; Railway provides its own DATABASE_URL in prod.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/patriothacks

# Comma-separated origins allowed to call this API (civic-match frontend).
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
